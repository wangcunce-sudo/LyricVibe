# ============================================================
# LyricVibe 环境变量配置
# 复制此文件为 .env.local 并填入你的 API Keys
# ============================================================

# ── AI API Keys（三选一即可）──────────────────────────────

# 方案 A: OpenAI
# 获取地址: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# 方案 B: DeepSeek（推荐：性价比最高）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# 方案 C: Anthropic Claude
# 获取地址: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Remotion AWS Lambda（可选，云端渲染用）─────────────────
# 配置方法: 见 REMOTION_LAMBDA_GUIDE.md
# REMOTION_AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXX
# REMOTION_AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
# REMOTION_AWS_REGION=ap-northeast-1
